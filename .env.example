# Vertybių testas — environment configuration
# Copy to .env and fill in. On shared hosting you can also set these
# as real environment variables in the hosting panel.

# development | production
APP_ENV=production
APP_URL=https://example.lt

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=vertybes
MYSQL_USERNAME=vertybes
MYSQL_PASSWORD=

# Admin API key for CLI/maintenance operations (migrations etc.).
# MUST be changed — the app refuses the placeholder in production.
ADMIN_API_KEY=

# Salt for hashing visitor IPs before storage (GDPR). Set once, keep stable.
IP_HASH_SALT=

# OpenAI (optional here — can also be set in the admin panel; env wins)
OPENAI_API_KEY=
